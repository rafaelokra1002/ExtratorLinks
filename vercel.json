{
  "version": 2,
  "functions": {
    "server.js": {
      "maxDuration": 60
    },
    "api/analisar.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/analisar",
      "dest": "/api/analisar.js"
    },
    {
      "src": "/app.js",
      "dest": "/public/app.js"
    },
    {
      "src": "/styles.css",
      "dest": "/public/styles.css"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}